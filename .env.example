# ==========================================================
# BOS Platform
# Environment Configuration Template
# Copy this file to .env.local for local development
# ==========================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
VITE_APP_NAME=BOS Platform
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ----------------------------------------------------------
# API
# ----------------------------------------------------------
VITE_API_URL=https://api.bos-platform.com

# ----------------------------------------------------------
# Authentication
# ----------------------------------------------------------
VITE_AUTH_DOMAIN=auth.bos-platform.com
VITE_ORGANIZATION_ID=default_org

# ----------------------------------------------------------
# Internationalization
# ----------------------------------------------------------
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,ar

# ----------------------------------------------------------
# Features
# ----------------------------------------------------------
VITE_ENABLE_AI=true
VITE_ENABLE_GRAPH=true
VITE_ENABLE_GOVERNANCE=true
VITE_ENABLE_AUDIT=true

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
VITE_LOG_LEVEL=info

# ----------------------------------------------------------
# Analytics
# ----------------------------------------------------------
VITE_ENABLE_ANALYTICS=false
